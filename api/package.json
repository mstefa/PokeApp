{
  "name": "pokemon-api",
  "version": "1.1.0",
  "description": "PokeApp Backend API with Hexagonal Architecture",
  "main": "index.js",
  "scripts": {
    "start": "nodemon -L --exec node index.js",
    "dev": "nodemon -L --exec node index.js",
    "test": "mocha ./tests/**/*.spec.js --timeout 5000",
    "test:watch": "mocha ./tests/**/*.spec.js --watch --timeout 5000",
    "lint": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\""
  },
  "author": "Henry",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "mocha": "^10.2.0",
    "chai": "^4.3.10",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  }
}
