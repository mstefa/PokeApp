{
  "name": "pokemon-api",
  "version": "1.1.0",
  "description": "PokeApp Backend API with Hexagonal Architecture",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "mocha --loader=tsx 'tests/**/*.spec.js' --timeout 10000",
    "test:watch": "mocha --loader=tsx 'tests/**/*.spec.js' --watch --timeout 10000",
    "test:unit": "mocha --loader=tsx 'tests/models/**/*.spec.js' --timeout 10000",
    "test:integration": "mocha --import=tsx 'tests/integration/**/*.spec.js' --timeout 15000",
    "lint": "eslint src/ --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\""
  },
  "author": "Henry",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.0.0",
    "@types/sequelize": "^4.28.20",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "chai": "^4.3.10",
    "eslint": "^8.54.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
