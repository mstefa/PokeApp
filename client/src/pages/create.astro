---
import Layout from '../layouts/Layout.astro';
import CreatePokemon from '../components/CreatePokemon';

const apiBase = import.meta.env.PUBLIC_API_URL || import.meta.env.API_URL || process.env.API_URL || 'http://localhost:3002';
let types = [];
let error = null;

try {
  console.log(`[SSR create.astro] Resolved apiBase to: "${apiBase}"`);
  console.log(`[SSR create.astro] Fetching types from: ${apiBase}/types`);
  const res = await fetch(`${apiBase}/types`);
  if (res.ok) {
    types = await res.json();
  } else {
    console.error(`[SSR create.astro] Failed to fetch types. Status: ${res.status}`);
    error = `Error al obtener tipos de Pokémon (status ${res.status})`;
  }
} catch (err: any) {
  console.error(`[SSR create.astro] Catch block error:`, err);
  error = err.message;
}
---

<Layout title="Crear Pokémon">
  <div style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="text-align: center; margin-bottom: 2rem; color: var(--maincolor);">Crea tu propio Pokémon</h1>

    {error && (
      <div class="error-banner">
        <span>{error}</span>
      </div>
    )}

    <CreatePokemon client:load types={types} />
  </div>
</Layout>

<style>
  .error-banner {
    background-color: #ffdddd;
    color: #ff0000;
    padding: 1rem;
    border-radius: 0.25rem;
    margin-bottom: 1.5rem;
    font-weight: bold;
    text-align: center;
  }
</style>
