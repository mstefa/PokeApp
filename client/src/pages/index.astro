---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bienvenidos">
  <div class="container">
    <p class="text">Bienvenidos!</p>
    <a href="/home">
      <img label="enterImage" src="/resources/atrapalosya.png" class="img" alt="enterImage" />
    </a>
  </div>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 40rem;
  }

  .text {
    font-size: 5rem;
    font-family: 'Times New Roman', Times, serif;
    font-weight: 900;
  }

  .img {
    width: 25rem;
    height: 10rem;
    transition: width 0.2s, height 0.2s;
  }

  .img:hover {
    width: 25.5rem;
    height: 10.5rem;
  }
</style>
